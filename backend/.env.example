# Скопируйте этот файл в .env и задайте свои значения

# Секретный ключ для подписи JWT-токенов (сгенерируйте случайную строку)
SECRET_KEY=change-me-to-a-long-random-secret-key
APP_ENV=development

# Алгоритм подписи JWT (менять не нужно)
ALGORITHM=HS256

# Время жизни токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Путь к файлу SQLite (по умолчанию clinic.db в папке backend)
DB_PATH=clinic.db

# Rate limit для /auth/login и /auth/register (на процесс, in-memory).
# Считаются отдельно по IP и по номеру телефона.
# AUTH_LOGIN_RATE_LIMIT — макс. попыток входа за окно
# AUTH_LOGIN_RATE_WINDOW_SECONDS — длина окна в секундах (900 = 15 минут)
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW_SECONDS=900
# AUTH_REGISTER_RATE_LIMIT — макс. регистраций за окно (по IP и по телефону)
AUTH_REGISTER_RATE_LIMIT=3
AUTH_REGISTER_RATE_WINDOW_SECONDS=900
# true = включить rate limit на /auth/login и /auth/register (рекомендуется в проде).
# Для локального E2E (Playwright) часто ставят false.
AUTH_RATE_LIMIT_ENABLED=true
SEED_DEMO_DATA=true
SHOW_DEMO_CREDENTIALS_IN_DOCS=true

# Разрешённые источники для CORS (через запятую)
# По умолчанию локальная разработка на 3000 и 5173 портах
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Telegram bot settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_NOTIFY_ENABLED=true
TELEGRAM_CONNECT_TOKEN_TTL_MINUTES=15
TELEGRAM_HTTP_TIMEOUT_SECONDS=5
# true = локально без туннеля: привязка через getUpdates (удалит webhook при старте)
TELEGRAM_USE_POLLING=false
