# Скопируйте этот файл в .env и задайте свои значения

# Секретный ключ для подписи JWT-токенов (сгенерируйте случайную строку)
SECRET_KEY=change-me-to-a-long-random-secret-key

# Алгоритм подписи JWT (менять не нужно)
ALGORITHM=HS256

# Время жизни токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Путь к файлу SQLite (по умолчанию clinic.db в папке backend)
DB_PATH=clinic.db
