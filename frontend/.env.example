# Фронтенд: запросы идут на /api; в dev Vite проксирует на backend (см. vite.config.ts).
# Sentry в браузере: DSN из проекта React в sentry.io — только с префиксом VITE_
# Подставляется при сборке (npm run build); на хостинге задайте эту переменную для шага сборки фронта.
# VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...
